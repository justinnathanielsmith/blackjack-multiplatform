#!/usr/bin/env bash
# detekt wrapper script - runs detekt static analysis with formatting plugin
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DETEKT_CLI="$SCRIPT_DIR/tools/detekt-cli-1.23.7/bin/detekt-cli"
DETEKT_CONFIG="$SCRIPT_DIR/config/detekt.yml"
FORMATTING_PLUGIN="$SCRIPT_DIR/tools/detekt-formatting-1.23.7.jar"

if [[ ! -x "$DETEKT_CLI" ]]; then
    echo "Error: detekt-cli not found at $DETEKT_CLI" >&2
    exit 1
fi

if [[ ! -f "$FORMATTING_PLUGIN" ]]; then
    echo "Warning: detekt-formatting plugin not found, style checks will be limited" >&2
    PLUGIN_ARG=""
else
    PLUGIN_ARG="--plugins $FORMATTING_PLUGIN"
fi

# Default input paths
INPUT_PATHS="shared,sharedUI,androidApp,desktopApp,iosApp,wasmApp"

exec "$DETEKT_CLI" \
    --input "$INPUT_PATHS" \
    --config "$DETEKT_CONFIG" \
    --excludes "**/build/**,**/.gradle/**,**/.amper/**,**/.kotlin/**" \
    $PLUGIN_ARG \
    "$@"
